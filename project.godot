; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ng1"
run/main_scene="uid://dn4pdpp6bu7e3"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://images/icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"bunny": "res://dialogic/bunny.dch",
"lion": "res://dialogic/lion.dch"
}
directories/dtl_directory={
"bunny_lion_original": "res://images/characters/bunny_lion_original.dtl"
}
layout/style_directory={
"": "res://dialogic/styl.tres",
"styl": "res://dialogic/styl.tres"
}
variables={}
glossary/default_case_sensitive=true
layout/style_list=["res://dialogic/styl.tres"]
layout/default_style="res://dialogic/styl.tres"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1600
window/size/mode=3
window/size/borderless=true
window/stretch/mode="viewport"
window/stretch/aspect="keep_width"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[global_group]

main=""

